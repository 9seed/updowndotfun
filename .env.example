# Polymarket 交易配置（下单功能需要，需 Node.js 20.10+）
# 必填：私钥和钱包地址
POLY_PRIVATE_KEY=0x...
POLY_ADDRESS=0x...

# 可选：已从 Polymarket 获取的完整 API 凭证
# POLY_API_KEY=...
# POLY_SECRET=...
# POLY_PASSPHRASE=...

# 签名类型：0=EOA, 1=POLY_PROXY, 2=Gnosis Safe（代理钱包用1）
# POLY_SIGNATURE_TYPE=1

# Builder Program 凭证（无 Gas Claim 需要，从 polymarket.com/settings?tab=builder 获取）
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=

# 会话密钥派生用 pepper（256-bit 随机 hex，务必备份，丢失则所有派生地址不可恢复）
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PEPPER=
